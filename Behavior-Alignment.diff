+void UIManager::handleDataStoreUpdate(uint64 netHash, nlohmann::json const& updateJson) {
+    auto it = mImpl->contexts.find(netHash);
+    if (it == mImpl->contexts.end()) return;
+
+    auto* player = it->second.player;
+    if (!player) return;
+
+    std::string path = updateJson.value("Path", "");
+    auto const& data = updateJson["Data"];
+
+    // MessageBox button clicks
+    if (path == "button1.onClick" || path == "button2.onClick") {
+        int btn = (path == "button1.onClick") ? 1 : 2;
+        if (!it->second.msgBoxCallback) return;
+        auto cb = std::move(it->second.msgBoxCallback);
+        // Don't send CloseScreen — it doesn't work after sendUpdate.
+        // Instead, closeAndCleanupUI sends DataStore cleanup which tells client to close.
+        mImpl->closeAndCleanupUI(*player);
+        cb(*player, btn, std::nullopt);
+        return;
+    }
+    // CustomForm close button
+    if (path == "closeButton.onClick") {
+        if (!it->second.submitCallback) return;
+        auto                                     cb = std::move(it->second.submitCallback);
+        auto*                                    sp = static_cast<ServerPlayer*>(player);
+        ClientboundDataDrivenUICloseScreenPacket closePkt;
+        closePkt.mFormId            = it->second.currentFormId;
+        closePkt.mSerializationMode = ::SerializationMode::CerealOnly;
+        sp->mPacketSender.sendToClient(&sp->getUserEntityIdentifier(), closePkt);
+        cb(*player, FormCancelReason::UserClosed);
+        return;
+    }
+    // CustomForm layout button click
+    auto btnIt = it->second.buttonCallbacks.find(path);
+    if (btnIt != it->second.buttonCallbacks.end() && btnIt->second) {
+        btnIt->second(*player);
+        return;
+    }
+    // Interactive element routing (toggle, slider, dropdown, textfield)
+    auto obsIt = it->second.elementObservables.find(path);
+    if (obsIt == it->second.elementObservables.end()) return;
+
+    if (data.is_boolean()) {
+        if (auto obs = std::dynamic_pointer_cast<ObservableBoolean>(obsIt->second))
+            obs->_updateFromClient(data.get<bool>());
+    } else if (data.is_number()) {
+        if (auto obs = std::dynamic_pointer_cast<ObservableNumber>(obsIt->second))
+            obs->_updateFromClient(data.get<double>());
+    } else if (data.is_string()) {
+        if (auto obs = std::dynamic_pointer_cast<ObservableString>(obsIt->second))
+            obs->_updateFromClient(data.get<std::string>());
     }
 }
 
